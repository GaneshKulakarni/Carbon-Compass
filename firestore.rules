rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Shared community posts and memes can be read and written by anyone
    match /community_posts/{postId} {
      allow read, write: if true;
    }
    
    match /memes/{memeId} {
      allow read, write: if true;
    }
    
    // User-specific states
    match /users/{userId} {
      allow read, write: if true;
    }
    
    match /logs/{logId} {
      allow read, write: if true;
    }
    
    match /goals/{goalId} {
      allow read, write: if true;
    }
  }
}
